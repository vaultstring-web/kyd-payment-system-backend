# Core settings
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
ENV=local

# Security
JWT_SECRET=replace-with-strong-secret-at-least-32-chars
ENCRYPTION_KEY=replace-with-32-byte-hex-key-for-aes-256
ENCRYPTION_KEY_ID=key_v1

# Data stores
DATABASE_URL=postgres://kyd_user:kyd_password@postgres:5432/kyd_dev?sslmode=disable
DB_SSL_MODE=disable
REDIS_URL=redis:6379

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=vaultstring@gmail.com
SMTP_PASSWORD="cskzrnbnkyrzmryc"
SMTP_FROM=vaultstring@gmail.com
SMTP_USE_TLS=true
VERIFICATION_BASE_URL=http://localhost:3012/verification
EMAIL_VERIFICATION_EXPIRATION=24h

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:9000/api/v1/auth/google/callback
GOOGLE_TOKEN_ISSUER=https://accounts.google.com

# Gmail API Configuration (Alternative to SMTP)
GMAIL_API_ENABLED=false
GMAIL_CREDENTIALS_PATH=./config/gmail-credentials.json
GMAIL_TOKEN_PATH=./config/gmail-token.json

# Blockchain (Optional)
STELLAR_NETWORK_URL=https://horizon-testnet.stellar.org
STELLAR_ISSUER_ACCOUNT=GA...
STELLAR_SECRET_KEY=SA...
# Set to false for production to use real Stellar network
STELLAR_SIMULATION=true
RIPPLE_SERVER_URL=wss://s.altnet.rippletest.net:51233
RIPPLE_ISSUER_ADDRESS=r...
RIPPLE_SECRET_KEY=s...

# Risk Engine Configuration
RISK_ENABLE_CIRCUIT_BREAKER=true
RISK_MAX_DAILY_LIMIT=100000000
RISK_HIGH_VALUE_THRESHOLD=100000
RISK_ADMIN_APPROVAL_THRESHOLD=500000
RISK_RESTRICTED_COUNTRIES=KP,IR,SY,CU
RISK_ENABLE_DISPUTE_RESOLUTION=true
